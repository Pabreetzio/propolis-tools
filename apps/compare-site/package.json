{
  "name": "@propolis-tools/compare-site",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "manifest": "node scripts/build-manifest.mjs",
    "generate": "corepack pnpm --filter @propolis-tools/renderer build && corepack pnpm --filter @propolis-tools/core build && tsx scripts/generate-fixtures.ts"
  },
  "dependencies": {
    "@propolis-tools/core": "workspace:*",
    "@propolis-tools/renderer": "workspace:*",
    "pngjs": "^7.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@types/pngjs": "^6.0.5",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "tsx": "^4.20.6",
    "typescript": "^5.4.0",
    "vite": "^5.3.0"
  }
}
